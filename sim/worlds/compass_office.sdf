<?xml version="1.0" ?>
<sdf version="1.10">
  <world name="compass_office">
    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics" />
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands" />
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster" />
    <plugin filename="gz-sim-imu-system" name="gz::sim::systems::Imu" />
    <plugin filename="gz-sim-contact-system" name="gz::sim::systems::Contact" />
    <plugin filename="gz-sim-sensors-system" name="gz::sim::systems::Sensors">
      <render_engine>ogre2</render_engine>
    </plugin>
    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>0.5 0.1 -0.9</direction>
    </light>
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>15.000 15.000</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>15.000 15.000</size>
            </plane>
          </geometry>
          <material>
            <ambient>0.550 0.550 0.580 1</ambient>
            <diffuse>0.550 0.550 0.580 1</diffuse>
            <specular>0.650 0.650 0.680 1</specular>
          </material>
        </visual>
      </link>
    </model>
    <model name="perimeter_north">
      <static>true</static>
      <pose>0.000000 4.000000 0.750000 0.000000 0.000000 0.000000</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>10.000000 0.100000 1.500000</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>10.000000 0.100000 1.500000</size>
            </box>
          </geometry>
          <material>
            <ambient>0.400 0.400 0.450 1</ambient>
            <diffuse>0.400 0.400 0.450 1</diffuse>
            <specular>0.500 0.500 0.550 1</specular>
          </material>
        </visual>
      </link>
    </model>
    <model name="perimeter_south">
      <static>true</static>
      <pose>0.000000 -4.000000 0.750000 0.000000 0.000000 0.000000</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>10.000000 0.100000 1.500000</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>10.000000 0.100000 1.500000</size>
            </box>
          </geometry>
          <material>
            <ambient>0.400 0.400 0.450 1</ambient>
            <diffuse>0.400 0.400 0.450 1</diffuse>
            <specular>0.500 0.500 0.550 1</specular>
          </material>
        </visual>
      </link>
    </model>
    <model name="perimeter_west">
      <static>true</static>
      <pose>-5.000000 0.000000 0.750000 0.000000 0.000000 1.570796</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>8.000000 0.100000 1.500000</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>8.000000 0.100000 1.500000</size>
            </box>
          </geometry>
          <material>
            <ambient>0.400 0.400 0.450 1</ambient>
            <diffuse>0.400 0.400 0.450 1</diffuse>
            <specular>0.500 0.500 0.550 1</specular>
          </material>
        </visual>
      </link>
    </model>
    <model name="perimeter_east">
      <static>true</static>
      <pose>5.000000 0.000000 0.750000 0.000000 0.000000 1.570796</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>8.000000 0.100000 1.500000</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>8.000000 0.100000 1.500000</size>
            </box>
          </geometry>
          <material>
            <ambient>0.400 0.400 0.450 1</ambient>
            <diffuse>0.400 0.400 0.450 1</diffuse>
            <specular>0.500 0.500 0.550 1</specular>
          </material>
        </visual>
      </link>
    </model>
    <model name="pillar_center">
      <static>true</static>
      <pose>2.000000 3.000000 0.600000 0.000000 0.000000 0.000000</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.300000</radius>
              <length>1.200000</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.300000</radius>
              <length>1.200000</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.550 0.270 0.180 1</ambient>
            <diffuse>0.550 0.270 0.180 1</diffuse>
            <specular>0.650 0.370 0.280 1</specular>
          </material>
        </visual>
      </link>
    </model>
    <model name="shelf_left">
      <static>true</static>
      <pose>-2.500000 2.200000 0.400000 0.000000 0.000000 0.000000</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>1.200000 0.500000 0.800000</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>1.200000 0.500000 0.800000</size>
            </box>
          </geometry>
          <material>
            <ambient>0.300 0.450 0.650 1</ambient>
            <diffuse>0.300 0.450 0.650 1</diffuse>
            <specular>0.400 0.550 0.750 1</specular>
          </material>
        </visual>
      </link>
    </model>
    <model name="shelf_right">
      <static>true</static>
      <pose>3.000000 -2.400000 0.400000 0.000000 0.000000 0.000000</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <box>
              <size>0.600000 1.400000 0.800000</size>
            </box>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <box>
              <size>0.600000 1.400000 0.800000</size>
            </box>
          </geometry>
          <material>
            <ambient>0.300 0.450 0.650 1</ambient>
            <diffuse>0.300 0.450 0.650 1</diffuse>
            <specular>0.400 0.550 0.750 1</specular>
          </material>
        </visual>
      </link>
    </model>
    <!-- 반응형 보행자: 자체 DiffDrive 를 가진 동적 원기둥 "사람".
         reactive_pedestrian 노드가 ped/cmd_vel 로 조향하고 ped/odom 으로 위치를 읽는다. -->
    <model name="pedestrian">
      <pose>4.0 -2.0 0.0 0 0 1.5708</pose>
      <link name="ped_base">
        <pose>0 0 0.6 0 0 0</pose>
        <inertial>
          <mass>60.0</mass>
          <inertia>
            <ixx>9.0</ixx><iyy>9.0</iyy><izz>1.0</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
        <collision name="collision">
          <geometry><cylinder><radius>0.25</radius><length>1.2</length></cylinder></geometry>
        </collision>
        <visual name="visual">
          <geometry><cylinder><radius>0.25</radius><length>1.2</length></cylinder></geometry>
          <material>
            <ambient>0.85 0.55 0.20 1</ambient>
            <diffuse>0.85 0.55 0.20 1</diffuse>
            <specular>0.95 0.65 0.30 1</specular>
          </material>
        </visual>
      </link>
      <!-- 좌/우 작은 바퀴: DiffDrive 가 구동할 수 있도록 연속 회전 관절. -->
      <link name="ped_left_wheel">
        <pose>0 0.18 0.05 1.5708 0 0</pose>
        <inertial><mass>0.5</mass>
          <inertia><ixx>1e-3</ixx><iyy>1e-3</iyy><izz>1e-3</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
        </inertial>
        <collision name="collision"><geometry><cylinder><radius>0.05</radius><length>0.04</length></cylinder></geometry></collision>
        <visual name="visual"><geometry><cylinder><radius>0.05</radius><length>0.04</length></cylinder></geometry></visual>
      </link>
      <link name="ped_right_wheel">
        <pose>0 -0.18 0.05 1.5708 0 0</pose>
        <inertial><mass>0.5</mass>
          <inertia><ixx>1e-3</ixx><iyy>1e-3</iyy><izz>1e-3</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
        </inertial>
        <collision name="collision"><geometry><cylinder><radius>0.05</radius><length>0.04</length></cylinder></geometry></collision>
        <visual name="visual"><geometry><cylinder><radius>0.05</radius><length>0.04</length></cylinder></geometry></visual>
      </link>
      <joint name="ped_left_joint" type="revolute">
        <parent>ped_base</parent><child>ped_left_wheel</child>
        <axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
      </joint>
      <joint name="ped_right_joint" type="revolute">
        <parent>ped_base</parent><child>ped_right_wheel</child>
        <axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
      </joint>
      <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <left_joint>ped_left_joint</left_joint>
        <right_joint>ped_right_joint</right_joint>
        <wheel_separation>0.36</wheel_separation>
        <wheel_radius>0.05</wheel_radius>
        <odom_publish_frequency>20</odom_publish_frequency>
        <topic>ped/cmd_vel</topic>
        <odom_topic>ped/odom</odom_topic>
        <frame_id>odom</frame_id>
        <child_frame_id>pedestrian</child_frame_id>
      </plugin>
    </model>
  </world>
</sdf>
